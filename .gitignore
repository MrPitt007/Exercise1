## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono Auto Generated Files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017 cache/options directory
.vs/

# If you have a Mac:
# .vscode/
# *.[Cc]ache
# *.plist

# Visual Studio Code settings
.vscode/

# Visual Studio auto-generated files
Generated\ Files/

# Backup & report files from VS or extensions
*_i.c
*_p.c
*.ilk
*.meta
*.obj
*.pch
*.pdb
*.pgc
*.pgd
*.rsp
*.sdf
*.cachefile
*.log
*.tlog
*.tmp
*.vspscc
_RegisterAppHost.log
*.log

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# Nunit
*.VisualState.xml
TestResult.xml

# Unit test temp files
*.coverage
*.coveragexml

# Azure
csx/
*.build.csdef

# Windows Store app package directories and files
AppPackages/
BundleArtifacts/
Package.StoreAssociation.xml
Package.appxmanifest
*.appx
*.appxbundle
*.appxupload

# Others
*.vspscc
*_i.c
*_p.c
*_h.h
*.dbmdl
*.bak
*.swp
*.orig

# Rider
.idea/

# JetBrains Rider settings
*.sln.iml

# Localhistory files
.localhistory/

# Node_modules (if using JS tooling)
node_modules/

# DotNet CLI
project.lock.json
project.fragment.lock.json
artifacts/

# Autogenerated build files
*.dll
*.exe

# Visual Studio backup files
*.bak
*.Backup
*.tmp

# git ignore itself
.gitignore
``
